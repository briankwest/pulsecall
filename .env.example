# SignalWire
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_API_TOKEN=
SIGNALWIRE_SPACE=yourspace.signalwire.com
SIGNALWIRE_PHONE_NUMBER=+15551234567
DISPLAY_PHONE_NUMBER=

# SWML callback auth (required for outbound callback URLs)
SWML_BASIC_AUTH_USER=pulsecall
SWML_BASIC_AUTH_PASSWORD=
SWML_PROXY_URL_BASE=

# AI
AI_MODEL=gpt-oss-120b
AI_TOP_P=0.5
AI_TEMPERATURE=0.3

# Dialer
MAX_OUTBOUND_CONCURRENT=2
OUTBOUND_SCHEDULE=

# Server
HOST=0.0.0.0
PORT=3000
DATABASE_PATH=pulsecall.db
